import pandas as pd
customers = pd.re  ad_csv('/home/rocky/Documents/Projects/Data Analysis/olist_project/Data/cust data/olist_customers_dataset.csv')
orders = pd.read_csv('/home/rocky/Documents/Projects/Data Analysis/olist_project/Data/cust data/olist_orders_dataset.csv')
order_items = pd.read_csv('/home/rocky/Documents/Projects/Data Analysis/olist_project/Data/cust data/olist_order_items_dataset.csv')
products = pd.read_csv('/home/rocky/Documents/Projects/Data Analysis/olist_project/Data/cust data/olist_products_dataset.csv')
reviews = pd.read_csv('/home/rocky/Documents/Projects/Data Analysis/olist_project/Data/cust data/olist_order_reviews_dataset.csv')
category_translation = pd.read_csv('/home/rocky/Documents/Projects/Data Analysis/olist_project/Data/cust data/product_category_name_translation.csv')

# Merge into one master dataframe
df = orders.merge(order_items, on='order_id')
df = df.merge(products, on='product_id')
df = df.merge(customers, on='customer_id')
df = df.merge(reviews, on='order_id', how='left')
df = df.merge(category_translation, on='product_category_name', how='left')

#Clean the DATA
# Convert date columns
df['order_purchase_timestamp'] = pd.to_datetime(df['order_purchase_timestamp'])

# Filter only delivered orders
df = df[df['order_status'] == 'delivered']

# Drop nulls in critical columns
df.dropna(subset=['product_category_name_english', 'review_score'], inplace=True)

# Extract month and year
df['month'] = df['order_purchase_timestamp'].dt.to_period('M')
df['year'] = df['order_purchase_timestamp'].dt.year

## **Revenue Trends**
revenue_trend = df.groupby('month')['price'].sum().reset_index()
revenue_trend.columns = ['month', 'revenue']
revenue_trend['month'] = revenue_trend['month'].astype(str)

import matplotlib.pyplot as plt
plt.figure(figsize=(14,5))
plt.plot(revenue_trend['month'], revenue_trend['revenue'], marker='o')
plt.xticks(rotation=45)
plt.title('Monthly Revenue Trend')
plt.tight_layout()
plt.savefig('revenue_trend.png')
plt.show()



## **Top Product Categories**

top_categories = df.groupby('product_category_name_english')['price'].sum().sort_values(ascending=False).head(10)

top_categories.plot(kind='barh', figsize=(10,6), color='steelblue')
plt.title('Top 10 Revenue-Generating Categories')
plt.xlabel('Total Revenue (BRL)')
plt.tight_layout()
plt.savefig('top_categories.png')
plt.show()

## **Customer Satisfaction by Region**

satisfaction = df.groupby('customer_state')['review_score'].mean().sort_values(ascending=False).reset_index()

import seaborn as sns
plt.figure(figsize=(14,5))
sns.barplot(data=satisfaction, x='customer_state', y='review_score', palette='RdYlGn')
plt.title('Average Customer Satisfaction by State')
plt.tight_layout()
plt.savefig('satisfaction_by_region.png')
plt.show()


## **Export Clean Data for Dashboard**
df.to_csv('/home/rocky/Documents/Projects/Data Analysis/olist_project/Data/olist_clean.csv', index=False)
